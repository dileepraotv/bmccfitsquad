# -----------------------------------------------------------------------
# BMCC Bot — environment variable template
# Copy this file to .env and fill in every value before running locally.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# PostgreSQL connection string
# Railway: copy from the Postgres service's "Connect" tab (use the Internal URL)
# Local:   postgresql://user:password@localhost:5432/bmcc_bot
DATABASE_URL=

# Upstash Redis URL
# Use rediss:// (TLS) for Upstash — copy from the Upstash console
# Local plain Redis: redis://localhost:6379
REDIS_URL=

# Strava API credentials
# Create an app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your Railway domain
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Random string used to verify Strava webhook subscription challenges
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Telegram bot token — create a bot with @BotFather
TELEGRAM_BOT_TOKEN=

# Secret used to validate incoming Telegram webhook requests (1–256 chars, a-z A-Z 0-9 _ -)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=

# Fernet encryption key for storing Strava tokens at rest (base64-encoded 32-byte key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: back this up — losing it means all stored tokens become unreadable
ENCRYPTION_KEY=

# "production" → enables Telegram webhook, hides /docs
# "development" → shows /docs, deletes webhook (use polling locally)
# "polling"     → same as development; explicitly enables local polling mode
APP_ENV=production

# Public HTTPS base URL of your deployment (no trailing slash)
# Railway: https://your-app.up.railway.app
# Local with ngrok: https://abc123.ngrok.io
BASE_URL=https://your-app.railway.app
