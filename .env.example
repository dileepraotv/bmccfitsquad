# -----------------------------------------------------------------------
# BMCC Bot — environment variable template
# Copy this file to .env and fill in every value before running locally.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection string
# Format: postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Upstash Redis URL (use rediss:// with TLS)
# Get from: https://console.upstash.com → your database → Redis URL
REDIS_URL=

# Strava API credentials
# Create an app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your Render domain (e.g. bmccfitsquad.onrender.com)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Random string used to verify Strava webhook subscription challenges
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Telegram bot token — create a bot with @BotFather
TELEGRAM_BOT_TOKEN=

# Secret used to validate incoming Telegram webhook requests (1–256 chars, a-z A-Z 0-9 _ -)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=

# Fernet encryption key for storing Strava tokens at rest (base64-encoded 32-byte key)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: back this up separately — losing it makes all stored tokens unreadable
ENCRYPTION_KEY=

# "production" → enables Telegram webhook, hides /docs
# "development" → shows /docs
APP_ENV=production

# Public HTTPS base URL of this deployment (no trailing slash)
# Render: https://bmccfitsquad.onrender.com
# Local with ngrok: https://abc123.ngrok.io
BASE_URL=https://bmccfitsquad.onrender.com
